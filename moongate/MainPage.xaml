<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Moongate.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid
        Padding="24"
        Background="{ThemeResource MoongateAppBackgroundBrush}"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource MoongateTextBrush}"
                    Text="Moongate" />
                <TextBlock
                    Foreground="{ThemeResource MoongateMutedTextBrush}"
                    Text="Calendar" />
            </StackPanel>

            <Button
                Grid.Column="1"
                HorizontalAlignment="Right"
                Click="TodayButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon
                        Foreground="{ThemeResource MoongateCommandIconBrush}"
                        Symbol="Calendar" />
                    <TextBlock
                        Foreground="{ThemeResource MoongateCommandTextBrush}"
                        Text="Today" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="320" />
                <ColumnDefinition Width="*" MinWidth="640" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        x:Name="SelectedDateTitle"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource MoongateTextBrush}" />
                    <TextBlock
                        x:Name="SelectedDateSubtitle"
                        Foreground="{ThemeResource MoongateMutedTextBrush}" />
                </StackPanel>

                <Button
                    Grid.Row="1"
                    HorizontalAlignment="Left"
                    Click="AddEventButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon
                            Foreground="{ThemeResource MoongateCommandIconBrush}"
                            Symbol="Add" />
                        <TextBlock
                            Foreground="{ThemeResource MoongateCommandTextBrush}"
                            Text="Add event" />
                    </StackPanel>
                </Button>

                <Grid Grid.Row="2">
                    <ListView
                        x:Name="AgendaList"
                        IsItemClickEnabled="True"
                        ItemClick="AgendaList_ItemClick"
                        ItemsSource="{x:Bind VisibleEvents, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    Padding="0,10"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Foreground="{ThemeResource MoongateMutedTextBrush}"
                                        Text="{Binding TimeLabel}" />

                                    <StackPanel Grid.Column="1" Spacing="3">
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource MoongateTextBrush}"
                                            Text="{Binding Title}" />
                                        <TextBlock
                                            Foreground="{ThemeResource MoongateMutedTextBrush}"
                                            Text="{Binding DetailLabel}" />
                                        <TextBlock
                                            Foreground="{ThemeResource MoongateMutedTextBrush}"
                                            Text="{Binding Notes}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        x:Name="EmptyAgendaText"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource MoongateMutedTextBrush}"
                        Text="No events scheduled." />
                </Grid>
            </Grid>

            <Grid
                Grid.Column="1"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Click="PreviousMonthButton_Click"
                        ToolTipService.ToolTip="Previous month">
                        <SymbolIcon
                            Foreground="{ThemeResource MoongateCommandIconBrush}"
                            Symbol="Back" />
                    </Button>

                    <TextBlock
                        x:Name="MonthTitle"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource MoongateTextBrush}" />

                    <Button
                        Grid.Column="2"
                        Click="NextMonthButton_Click"
                        ToolTipService.ToolTip="Next month">
                        <SymbolIcon
                            Foreground="{ThemeResource MoongateCommandIconBrush}"
                            Symbol="Forward" />
                    </Button>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource MoongateCalendarSurfaceBrush}"
                    BorderBrush="{ThemeResource MoongatePanelBorderBrush}"
                    BorderThickness="1">
                    <canvas:CanvasControl
                        x:Name="CalendarCanvas"
                        ClearColor="Transparent"
                        Draw="CalendarCanvas_Draw"
                        PointerPressed="CalendarCanvas_PointerPressed" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
