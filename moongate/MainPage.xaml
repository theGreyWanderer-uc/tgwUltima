<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Moongate.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid
        Padding="24"
        Background="{ThemeResource MoongateAppBackgroundBrush}"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource MoongateTextBrush}"
                    Text="Moongate" />
                <TextBlock
                    Foreground="{ThemeResource MoongateMutedTextBrush}"
                    Text="Calendar" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Click="TodayButton_Click"
                    ToolTipService.ToolTip="Today (Ctrl+T)">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon
                            Foreground="{ThemeResource MoongateCommandIconBrush}"
                            Symbol="Calendar" />
                        <TextBlock
                            Foreground="{ThemeResource MoongateCommandTextBrush}"
                            Text="Today" />
                    </StackPanel>
                </Button>

                <Button
                    Click="AddEventButton_Click"
                    ToolTipService.ToolTip="Add event (Ctrl+N)">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon
                            Foreground="{ThemeResource MoongateCommandIconBrush}"
                            Symbol="Add" />
                        <TextBlock
                            Foreground="{ThemeResource MoongateCommandTextBrush}"
                            Text="Add event" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" MinWidth="360" />
                <ColumnDefinition Width="*" MinWidth="640" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="TimelinePane"
                Background="{ThemeResource MoongateCalendarSurfaceBrush}"
                BorderBrush="{ThemeResource MoongatePanelBorderBrush}"
                BorderThickness="1"
                SizeChanged="TimelinePane_SizeChanged">
                <Grid>
                    <canvas:CanvasControl
                        x:Name="TimelineCanvas"
                        ClearColor="Transparent"
                        Draw="TimelineCanvas_Draw"
                        PointerWheelChanged="TimelineCanvas_PointerWheelChanged" />

                    <Canvas
                        x:Name="TimelineCardsCanvas"
                        IsHitTestVisible="True"
                        PointerWheelChanged="TimelineCanvas_PointerWheelChanged" />
                </Grid>
            </Border>

            <Grid
                Grid.Column="1"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Click="PreviousMonthButton_Click"
                        ToolTipService.ToolTip="Previous month (Alt+Left)">
                        <SymbolIcon
                            Foreground="{ThemeResource MoongateCommandIconBrush}"
                            Symbol="Back" />
                    </Button>

                    <TextBlock
                        x:Name="MonthTitle"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource MoongateTextBrush}" />

                    <Button
                        Grid.Column="2"
                        Click="NextMonthButton_Click"
                        ToolTipService.ToolTip="Next month (Alt+Right)">
                        <SymbolIcon
                            Foreground="{ThemeResource MoongateCommandIconBrush}"
                            Symbol="Forward" />
                    </Button>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource MoongateCalendarSurfaceBrush}"
                    BorderBrush="{ThemeResource MoongatePanelBorderBrush}"
                    BorderThickness="1">
                    <canvas:CanvasControl
                        x:Name="CalendarCanvas"
                        ClearColor="Transparent"
                        Draw="CalendarCanvas_Draw"
                        PointerPressed="CalendarCanvas_PointerPressed" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
