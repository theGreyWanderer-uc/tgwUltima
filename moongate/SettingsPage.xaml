<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Moongate.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        Padding="28"
        Background="{ThemeResource MoongateAppBackgroundBrush}"
        RowSpacing="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="{ThemeResource MoongateTextBrush}"
                Text="Settings" />
            <TextBlock
                Foreground="{ThemeResource MoongateMutedTextBrush}"
                Text="Moongate preferences and configuration" />
        </StackPanel>

        <Grid
            Grid.Row="1"
            ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="8"
                Background="{ThemeResource MoongatePanelBackgroundBrush}"
                BorderBrush="{ThemeResource MoongatePanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <ListView
                    x:Name="SettingsCategoryList"
                    SelectionChanged="SettingsCategoryList_SelectionChanged"
                    SelectionMode="Single">
                    <ListViewItem Tag="general">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <SymbolIcon
                                Foreground="{ThemeResource MoongateNavigationIconBrush}"
                                Symbol="Setting" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource MoongateNavigationTextBrush}"
                                Text="General" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="appearance">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon
                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                Foreground="{ThemeResource MoongateNavigationIconBrush}"
                                Glyph="&#xE706;" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource MoongateNavigationTextBrush}"
                                Text="Appearance" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="configuration">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Grid Width="22" Height="22">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="18"
                                    Foreground="{ThemeResource MoongateNavigationIconBrush}"
                                    Glyph="&#xEA18;" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="7"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource MoongateNavigationIconBrush}"
                                    Text="&gt;_" />
                            </Grid>
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource MoongateNavigationTextBrush}"
                                Text="Configuration" />
                        </StackPanel>
                    </ListViewItem>
                </ListView>
            </Border>

            <Border
                Grid.Column="1"
                Padding="24"
                Background="{ThemeResource MoongatePanelBackgroundBrush}"
                BorderBrush="{ThemeResource MoongatePanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <ScrollViewer>
                    <Grid RowSpacing="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock
                                x:Name="SettingsSectionTitle"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource MoongateTextBrush}" />
                            <TextBlock
                                x:Name="SettingsSectionSubtitle"
                                Foreground="{ThemeResource MoongateMutedTextBrush}" />
                        </StackPanel>

                        <StackPanel
                            x:Name="GeneralSettingsPanel"
                            Grid.Row="1"
                            Spacing="18">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="3">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource MoongateTextBrush}"
                                        Text="Week starts on" />
                                    <TextBlock
                                        Foreground="{ThemeResource MoongateMutedTextBrush}"
                                        Text="Calendar grid default" />
                                </StackPanel>

                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{ThemeResource MoongateTextBrush}"
                                    Text="Sunday" />
                            </Grid>

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="3">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource MoongateTextBrush}"
                                        Text="Event store" />
                                    <TextBlock
                                        Foreground="{ThemeResource MoongateMutedTextBrush}"
                                        Text="Current local data format" />
                                </StackPanel>

                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{ThemeResource MoongateTextBrush}"
                                    Text="JSON" />
                            </Grid>
                        </StackPanel>

                        <StackPanel
                            x:Name="AppearanceSettingsPanel"
                            Grid.Row="1"
                            Spacing="18"
                            Visibility="Collapsed">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="280" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="3">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource MoongateTextBrush}"
                                        Text="Theme" />
                                    <TextBlock
                                        Foreground="{ThemeResource MoongateMutedTextBrush}"
                                        Text="Active Moongate palette" />
                                </StackPanel>

                                <ComboBox
                                    x:Name="ThemeSelector"
                                    Grid.Column="1"
                                    MinWidth="260"
                                    HorizontalAlignment="Right"
                                    SelectionChanged="ThemeSelector_SelectionChanged" />
                            </Grid>
                        </StackPanel>

                        <StackPanel
                            x:Name="ConfigurationSettingsPanel"
                            Grid.Row="1"
                            Spacing="18"
                            Visibility="Collapsed">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="3">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource MoongateTextBrush}"
                                        Text="Diagnostics" />
                                    <TextBlock
                                        x:Name="LogPathText"
                                        Foreground="{ThemeResource MoongateMutedTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <ToggleSwitch
                                    x:Name="DebugLoggingSwitch"
                                    Grid.Column="1"
                                    Foreground="{ThemeResource MoongateTextBrush}"
                                    Header="Debug logging"
                                    OffContent="Off"
                                    OnContent="On"
                                    Toggled="DebugLoggingSwitch_Toggled" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
