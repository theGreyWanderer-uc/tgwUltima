<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Moongate.AgendaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        Padding="28"
        Background="{ThemeResource MoongateAppBackgroundBrush}"
        RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="{ThemeResource MoongateTextBrush}"
                Text="Agenda" />
            <TextBlock
                Foreground="{ThemeResource MoongateMutedTextBrush}"
                Text="Upcoming events over the next 30 days" />
        </StackPanel>

        <Grid Grid.Row="1">
            <ListView
                x:Name="AgendaList"
                ItemsSource="{x:Bind UpcomingEvents, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Foreground="{ThemeResource MoongateMutedTextBrush}"
                                Text="{Binding DateLabel}" />

                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource MoongateTextBrush}"
                                    Text="{Binding Title}" />
                                <TextBlock
                                    Foreground="{ThemeResource MoongateMutedTextBrush}"
                                    Text="{Binding DetailLabel}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                x:Name="EmptyText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource MoongateMutedTextBrush}"
                Text="No upcoming events." />
        </Grid>
    </Grid>
</Page>
